#!/bin/sh /etc/rc.common

START=98
STOP=20
USE_PROCD=1
PROG=/usr/bin/fancontrol

start_service() {
	local mode

	mode="$(uci -q get fancontrol.settings.mode 2>/dev/null)"
	case "$mode" in
		auto|fixed) ;;
		*) return 0 ;;
	esac

	procd_open_instance main
	procd_set_param command "$PROG" run
	procd_set_param respawn 3600 5 0
	procd_close_instance

	procd_open_instance watchdog
	procd_set_param command "$PROG" watchdog
	procd_set_param respawn 3600 5 0
	procd_close_instance
}

stop_service() {
	"$PROG" restore-system >/dev/null 2>&1 || true
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger fancontrol
}
